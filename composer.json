{
    "name": "thupsi/craft-singleton",
    "description": "Expands single sections as individual sources in the Craft CP and adds a persistent left-nav sidebar to the single entry editor.",
    "type": "craft-plugin",
    "license": "proprietary",
    "authors": [
        {
            "name": "Thanasis Psarros"
        }
    ],
    "require": {
        "craftcms/cms": "^5.9.0"
    },
    "autoload": {
        "psr-4": {
            "thupsi\\singlesmanager\\": "src/"
        }
    },
    "extra": {
        "handle": "_singles-manager",
        "name": "Singleton",
        "schemaVersion": "1.0.0",
        "class": "thupsi\\singlesmanager\\Plugin",
        "aliases": {
            "@singlesmanager": "src"
        }
    },
    "config": {
        "allow-plugins": {
            "craftcms/plugin-installer": true,
            "yiisoft/yii2-composer": true
        }
    }
}
