{#
 # Left-hand page sidebar injected into the standard Craft element editor
 # when a single entry is being edited.
 #
 # Variables (passed from Plugin::_injectSinglesSidebar):
 #   sidebarSources         - all ordered sources for the current page
 #   sectionUrlMap          - sectionUid → cpUrl map
 #   editableSingleSections - handle → Section, for the 'singles' key fallback
 #   currentSectionUid      - UID of the section being edited (for active highlight)
 #   pageIndexUrl           - URL of the current page's element index
 #}

{# Hide the sidebar container on narrower viewports where four columns
   (global nav + this sidebar + editor + details) would be too cramped. #}
<style>
@media only screen and (max-width: 79.9375rem) {
    #sidebar-container { display: none !important; }
}
</style>

<nav>
    <ul class="sources-list">
        {% set nestedUnderHeading = false %}
        {% for source in sidebarSources %}

            {% if source.type == 'heading' %}
                {% set headingKey = source.key ?? (source.heading|kebab) %}
                {% set sourceId = 'singleton-sources-' ~ headingKey %}
                {% if nestedUnderHeading %}
                        </ul>
                    </li>
                {% endif %}
                <li class="heading">
                    <div class="source-item source-item--heading">
                        <span class="type-heading-small">{{ (source.heading ?? '')|t('site') }}</span>
                        {% if (source.heading ?? '')|length %}
                            {% embed '_includes/disclosure-toggle' with {
                                persist: true,
                                storageKey: 'sources-list:' ~ headingKey,
                                controls: sourceId,
                                attributes: { class: 'source-item__toggle' }
                            } %}
                                {% block content %}
                                    <span class="cp-icon puny">{{ iconSvg('angle-down') }}</span>
                                    <span class="visually-hidden">{{ 'Expand {heading} sources'|t('app', { heading: source.heading }) }}</span>
                                {% endblock %}
                            {% endembed %}
                        {% endif %}
                    </div>
                    <ul id="{{ sourceId }}" class="sources-list">
                {% set nestedUnderHeading = true %}

            {% elseif (source.key ?? '') starts with 'single:' %}
                {% set uid = source.key|split(':')|last %}
                {% set url = sectionUrlMap[uid] ?? null %}
                {% if url %}
                    <li class="source-item source-item--link">
                        <a{% if uid == currentSectionUid %} class="sel"{% endif %} href="{{ url }}">
                            <span class="label">{{ source.label|t('site') }}</span>
                        </a>
                    </li>
                {% endif %}

            {% elseif (source.key ?? '') == 'singles' %}
                {# Fallback: config still uses the old grouped 'singles' key. #}
                {% if nestedUnderHeading %}
                        </ul>
                    </li>
                {% endif %}
                {% set sourceId = 'singleton-sources-singles' %}
                <li class="heading">
                    <div class="source-item source-item--heading">
                        <span class="type-heading-small">{{ 'Singles'|t('app') }}</span>
                        {% embed '_includes/disclosure-toggle' with {
                            persist: true,
                            storageKey: 'sources-list:singles',
                            controls: sourceId,
                            attributes: { class: 'source-item__toggle' }
                        } %}
                            {% block content %}
                                <span class="cp-icon puny">{{ iconSvg('angle-down') }}</span>
                                <span class="visually-hidden">{{ 'Expand {heading} sources'|t('app', { heading: 'Singles'|t('app') }) }}</span>
                            {% endblock %}
                        {% endembed %}
                    </div>
                    <ul id="{{ sourceId }}" class="sources-list">
                {% set nestedUnderHeading = true %}
                {% for handle, s in editableSingleSections %}
                    {% set url = sectionUrlMap[s.uid] ?? null %}
                    {% if url %}
                        <li class="source-item source-item--link">
                            <a{% if s.uid == currentSectionUid %} class="sel"{% endif %} href="{{ url }}">
                                <span class="label">{{ s.name|t('site') }}</span>
                            </a>
                        </li>
                    {% endif %}
                {% endfor %}

            {% elseif (source.key ?? '') starts with 'section:' %}
                {% set uid = source.key|split(':')|last %}
                {% set url = sectionUrlMap[uid] ?? null %}
                {% if url %}
                    <li class="source-item source-item--link">
                        <a href="{{ url }}"><span class="label">{{ source.label|t('site') }}</span></a>
                    </li>
                {% endif %}

            {% elseif source.key is defined and source.key is not empty %}
                {# Custom sources — navigate to the page index and pre-select via localStorage. #}
                <li class="source-item source-item--link">
                    <a href="{{ pageIndexUrl }}"
                       data-source-key="{{ source.key|e('html_attr') }}"
                       data-page-url="{{ pageIndexUrl|e('html_attr') }}"
                       class="singles-manager-custom-source">
                        <span class="label">{{ source.label|t('site') }}</span>
                    </a>
                </li>

            {% endif %}

        {% endfor %}
        {% if nestedUnderHeading %}
                </ul>
            </li>
        {% endif %}
    </ul>
</nav>

{% if craft.app.user.getIsAdmin() and craft.app.config.general.allowAdminChanges %}
<div id="source-actions" class="buttons">
    <button type="button" class="btn action-btn hairline singles-manager-customize-sources-btn"
            title="{{ 'Customize sources'|t('app') }}"
            aria-label="{{ 'Customize sources'|t('app') }}"></button>
</div>
{% js %}
(function () {
    var btn = document.querySelector('.singles-manager-customize-sources-btn');
    if (!btn) return;
    btn.addEventListener('click', function () {
        var modal = new Craft.CustomizeSourcesModal(
            {
                elementType: {{ 'craft\\elements\\Entry'|json_encode|raw }},
                rootSourceKey: null,
                sourceKey: null,
                $visibleSources: $([]),
                settings: { page: null },
                asyncSelectSourceByKey: function () { return Promise.resolve(); }
            },
            { hideOnEsc: false, hideOnShadeClick: false, onFadeOut: function () { modal.destroy(); } }
        );
    });
}());
{% endjs %}
{% endif %}
